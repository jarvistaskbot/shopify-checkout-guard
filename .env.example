DATABASE_URL=postgresql://postgres:password@localhost:5432/checkoutguard
SHOPIFY_API_KEY=your_shopify_api_key
SHOPIFY_API_SECRET=your_shopify_api_secret
APP_URL=https://your-app-domain.com
SENDGRID_API_KEY=
# Required in production — use a long random string (openssl rand -hex 32)
SECRET_KEY=your-secret-key-here
# BILLING_TEST_MODE: set true in local dev only; must be false or unset in production
BILLING_TEST_MODE=true
# Haiku AI incident analysis — set your Anthropic API key to enable
ANTHROPIC_API_KEY=
AI_ANALYSIS_ENABLED=true
# Gate OOS detection behind this flag (requires read_inventory scope)
OOS_ENABLED=false
